# Copy this to .env and fill in your values
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB — use a free MongoDB Atlas cluster
ROTTO_MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/rotto-garage

# JWT secret — make this something long and random
ROTTO_JWT_SECRET=your_super_secret_key_change_this

NODE_ENV=development
